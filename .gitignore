## Ignore Visual Studio temporary files, build results, and
## files generated by popular Visual Studio add-ons.
##
## Based on:
## https://github.com/github/gitignore/blob/master/VisualStudio.gitignore

# ===============================
# User-specific files
# ===============================
*.rsuser
*.suo
*.user
*.userosscache
*.sln.docstates
*.userprefs

# ===============================
# Mono / Xamarin
# ===============================
mono_crash.*

# ===============================
# Generated / Build results
# ===============================
generated/

# Visual Studio cache
.vs/
Generated Files/

# MSBuild / Visual Studio intermediate
obj/
**/obj/

# Build output folders
/bin/
/Bin/
/build/
/Build/
/Debug/
/Release/
/x64/
/x86/

# ===============================
# Test / Benchmark
# ===============================
[Tt]est[Rr]esult*/
[Bb]uild[Ll]og.*
BenchmarkDotNet.Artifacts/

# ===============================
# NUnit / Coverage
# ===============================
*.VisualState.xml
TestResult.xml
nunit-*.xml
coverage*.json
coverage*.xml
coverage*.info
*.coverage
*.coveragexml

# ===============================
# Visual C++ cache files
# ===============================
ipch/
*.aps
*.ncb
*.opendb
*.opensdf
*.sdf
*.cachefile
*.VC.db
*.VC.VC.opendb

# ===============================
# Visual Studio profiler / trace
# ===============================
*.psess
*.vsp
*.vspx
*.sap
*.e2e

# ===============================
# ReSharper / Rider / NCrunch
# ===============================
_ReSharper*/
*.[Rr]e[Ss]harper
*.DotSettings.user
_NCrunch_*
.*crunch*.local.xml
nCrunchTemp_*

# ===============================
# Logs / Dumps
# ===============================
log/
Log/
Logs/
[Dd]umps/
*.dmp
*.mdmp
*.rpt

# ===============================
# NuGet
# ===============================
*.nupkg
*.snupkg
**/[Pp]ackages/*
!**/[Pp]ackages/build/
*.nuget.props
*.nuget.targets

# ===============================
# Node.js
# ===============================
node_modules/

# ===============================
# Python
# ===============================
__pycache__/
*.pyc

# ===============================
# Azure / MSBuild
# ===============================
csx/
*.build.csdef
ecf/
rcf/
AppPackages/
BundleArtifacts/
*.appx
*.appxbundle
*.appxupload
*.binlog

# ===============================
# SQL Server
# ===============================
*.mdf
*.ldf
*.ndf

# ===============================
# ImGui
# ===============================
# 個人環境依存・毎回変わる
imgui.ini

# ===============================
# DirectX / Shader tools
# ===============================
dxcompiler.dll
dxil.dll
dxc.exe
**/dxcompiler.dll
**/dxil.dll
**/dxc.exe

# ===============================
# Binary outputs (拡張子)
# ===============================
*.pdb
*.ipdb
*.iobj
*.exe
*.dll
*.lib
*.ilk
*.log

# ===============================
# ★ アセット方針
# ===============================
# .obj は「ビルド中間」ではなく「アセット」として使うため
# 拡張子では除外しない（フォルダで制御する）
#
# resources/**/*.obj は Git 管理対象
git add resources/**/*.obj

# --- assimp libs are required for build ---
!externals/assimp/**/*.lib
!externals/assimp/**/*.dll
!externals/assimp/**/*.pdb-vc143-mtd.lib
!externals/assimp/**/*.pdb

git add -f externals/assimp/lib/Release/assimp-vc143-mt.lib
git add -f externals/assimp/lib/Debug/assimp-vc143-mtd.lib
git commit -m "Track assimp libs for CI"
git push

git add -f externals/assimp/lib/Debug/assimp-vc143-mtd.pdb
git commit -m "Add assimp debug PDB for CI"
git push
